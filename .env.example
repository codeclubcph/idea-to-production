# =============================================================================
# TaskFlow Workshop – Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Edit .env with your values (the defaults below work for local development)
#   3. Run:            docker compose up   (from the /infra directory)
#
# IMPORTANT: Never commit .env to version control.
#            .env.example (this file) is safe to commit.
# =============================================================================

# ----- PostgreSQL -----
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow         # change this in any shared or production environment
DB_PORT=5432                 # host port that PostgreSQL is exposed on

# ----- Backend (Spring Boot) -----
BACKEND_PORT=8080            # host port that the backend API is exposed on

# ----- Frontend (Next.js) -----
FRONTEND_PORT=3000           # host port that the frontend is exposed on
