# =============================================================================
# TaskFlow Workshop – Environment Variables
#
# ── LOCAL (Docker Compose) ───────────────────────────────────────────────────
#   1. Copy this file:   cp .env.example .env
#   2. Leave defaults as-is (they work out of the box)
#   3. Start everything from the REPO ROOT:
#        docker compose -f infra/docker-compose.yml up --build
#
# ── RAILWAY (cloud deployment) ───────────────────────────────────────────────
#   Railway manages its own environment variables in the dashboard.
#   You do NOT deploy this file to Railway.
#   See README.md → "Deploying to Railway" for the full walkthrough.
#
# IMPORTANT: Never commit .env to version control.
#            .env.example (this file) is safe to commit – it has no secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# LOCAL – PostgreSQL (used by Docker Compose only)
# On Railway these are set automatically by the Postgres plugin.
# -----------------------------------------------------------------------------
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow         # use a strong password in any shared environment
DB_PORT=5432                 # host port PostgreSQL is exposed on

# -----------------------------------------------------------------------------
# LOCAL – Backend (Spring Boot)
# On Railway, PORT is injected automatically – do not set it there.
# -----------------------------------------------------------------------------
BACKEND_PORT=8080            # host port the backend API is exposed on

# -----------------------------------------------------------------------------
# LOCAL – Frontend (Next.js)
# On Railway, set NEXT_PUBLIC_API_URL to your deployed backend's public URL.
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000           # host port the frontend is exposed on
NEXT_PUBLIC_API_URL=http://localhost:8080   # used when running frontend locally without Docker
