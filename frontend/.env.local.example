# Copy this file to .env.local for local development (outside Docker).
# Next.js reads .env.local automatically.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Do NOT put secrets in NEXT_PUBLIC_ variables.

# URL of the Spring Boot backend API
# Use http://localhost:8080 when running locally without Docker
# Use http://backend:8080 when running inside Docker Compose
NEXT_PUBLIC_API_URL=http://localhost:8080
